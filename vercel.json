{
  "version": 2,
  "name": "hr-automation-agent",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/agent_templates/hr_agent/src/server.js"
    },
    {
      "source": "/agent/(.*)",
      "destination": "/agent_templates/hr_agent/src/server.js"
    },
    {
      "source": "/health",
      "destination": "/agent_templates/hr_agent/src/server.js"
    }
  ]
}
